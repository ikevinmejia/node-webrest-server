{
  "exclude": ["node_modules", "dist"],
  "include": ["src", "src/test"],
  "compilerOptions": {
    "types": ["node", "jest"],
    "ignoreDeprecations": "6.0",

    "target": "ES2023",

    "module": "ESNext",
    "moduleResolution": "bundler",

    "rootDir": ".",
    "outDir": "./dist",

    "paths": { "*": ["./*"] },
    // "paths": {
    //   "@generated/*": ["prisma/generated/*"]
    // },

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  }
}
